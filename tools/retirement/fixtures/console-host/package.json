{
  "name": "xtrm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter './apps/*' dev",
    "build": "bun run build:packages && bun run build:apps",
    "build:packages": "bun run --filter './packages/*' build",
    "build:apps": "bun run --filter './apps/*' build",
    "start": "bun run apps/console/src/server/index.ts",
    "retirement:guard": "bun run tools/retirement/host-retirement-guard.ts --mode strict"
  }
}
